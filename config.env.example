# Copy this to config.env and edit — absolute paths, not relative.

# Where the AutoRound weights live (setup.sh will download here if empty).
MODEL_DIR=/path/to/models/Qwen3.6-27B-int4-AutoRound

# Where the Python venv for vLLM lives (setup.sh will create it here).
VENV_DIR=/path/to/venvs/qwen-vllm-autoround

# Where logs and scratch state (TMPDIR, HF_HOME) get written.
# Should be on a drive with ~50+ GB free — vLLM/HF caches can grow.
LOG_DIR=/path/to/logs

# --- tunable server knobs --------------------------------------------------

PORT=1234
SERVED_MODEL_NAME=qwen3.6-27b

# Max context length served. FP8 KV on 48 GB fits 200K with headroom; actual
# KV pool is ~172K so not all 3 concurrent seqs can reach 200K simultaneously.
MAX_MODEL_LEN=200000

# Max concurrent sequences. Solo user + 1-2 subagents = 3. Raise if you need
# more concurrency at the cost of per-seq KV headroom.
MAX_NUM_SEQS=3

# GPU memory fraction. vLLM's profiler suggests 0.93 with
# VLLM_MEMORY_PROFILER_ESTIMATE_CUDAGRAPHS=1; 0.92 is safe without.
GPU_MEMORY_UTIL=0.92

# --- GPU power envelope (requires passwordless sudo -n nvidia-smi) --------
# Blank = don't touch GPU power settings. Stacked RTX 3090s run ~84°C at 200W.
GPU_POWER_LIMIT=200
GPU_CLOCK_MAX=1500
